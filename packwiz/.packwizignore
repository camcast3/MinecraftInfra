# Tells `packwiz refresh` which files to skip when building index.toml.
# .gitignore syntax. https://packwiz.infra.link/reference/pack-format/packwizignore/
# Committed so every contributor + CI produces the same index.toml.

# Audit snapshot from import-curseforge-pack.ps1. Normally wiped at end of run,
# but excluded as defense in depth: if `packwiz refresh` walked it, each overlay
# mod would index twice and Forge would crash on duplicate ModIDs.
.import-staging/

.git/**
.gitattributes
.gitignore

# Repo-level docs inside packwiz/ that aren't part of the server pack.
README.md

# Cosmetic asset binaries hosted via GitHub Release — siblings' `*.pw.toml`
# metafiles ARE indexed. Excluding the raw binaries prevents `packwiz refresh`
# from double-indexing them, and avoids hitting GitHub's 100 MB blob limit on
# `git push`. import-curseforge-pack.ps1 leaves local copies in place by
# design; admin's job is to verify bytes match the GH Release attachment, not
# delete them.
config/fancymenu/assets/mahj_1294853429_mainmenu.fma
config/openloader/resources/resources.zip
