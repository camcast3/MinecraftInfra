# C2E2 packwiz pinning — committed, non-secret build metadata.
#
# Read by both:
#   - Portainer CE GitOps (docker-compose auto-loads .env from the
#     same directory as the compose file).
#   - PR 2's `infra/azure/scripts/publish-prism-pack.ps1`, which
#     bumps both variables atomically after uploading a new client
#     zip so the server's mod manifest and the client's bundled
#     mods always move in lockstep.
#
# Secrets (TS_AUTHKEY, RCON_PASSWORD, CF_API_KEY, VELOCITY_FORWARDING_SECRET,
# STORAGE_ACCOUNT, NAS_*, AZURE_*) MUST remain in Portainer's stack
# environment-variable UI — never add them here.

# Modpack version string (no leading "v" — the MOTD template prepends one).
# Matches the existing `modpack.yml` `version:` field convention.
PACK_VERSION=0.3.0

# Full 40-character commit SHA of the packwiz/ manifest the server should
# materialize. PR 1's bootstrap state: leave blank so the compose
# `${PACKWIZ_COMMIT_SHA:-main}` default kicks in and the server pulls from
# `main` HEAD — acceptable for first-deploy bootstrap, NOT for steady-state.
# PR 2's publish flow sets this to the SHA whose packwiz/ snapshot was just
# materialized into the published client zip, so server and client stay
# in lockstep.
PACKWIZ_COMMIT_SHA=
