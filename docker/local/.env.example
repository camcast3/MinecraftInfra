# Local stack env vars — copy to .env, fill in, and `docker compose up` from
# docker/local/. The real .env is gitignored by the root .gitignore.

# Velocity modern-forwarding shared secret. MUST equal the value in
# docker/local/velocity/forwarding.secret — Velocity reads it from disk
# (bind-mounted to /server/forwarding.secret) and PCF on c2e2 validates
# HMACs against this env var (injected into the PCF TOML at every start
# via PATCH_DEFINITIONS, same flow as prod).
#
# Generate with:
#   $b = New-Object byte[] 24
#   [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b)
#   ([Convert]::ToBase64String($b) -replace '[+/=]', '')
VELOCITY_FORWARDING_SECRET=replace-with-30-chars-of-random-base64-no-padding
