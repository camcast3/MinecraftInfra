# docker/azure/velocity/velocity.toml.tmpl
#
# Velocity proxy config template. refresh-env.sh runs envsubst on this file
# and writes the result to /data/minecraft/velocity/velocity.toml on the VM.
# Variables resolved at deploy time from Azure Key Vault via refresh-env.sh:
#   ${C2E2_TAILSCALE_IP}          — Tailscale IP of the Proxmox C2E2 server
# The Velocity modern-forwarding secret is NOT substituted into this template —
# Velocity reads it from /server/forwarding.secret, which is a single-file
# bind mount of /opt/minecraft/secrets/velocity_forwarding_secret.

config-version = "2.7"

# Bind on all interfaces; the NSG exposes only port 25565 externally.
bind = "0.0.0.0:25577"

# Velocity 3.3.0+ parses motd as MiniMessage — any `&` or `§` codes here would
# render as literal text. Plain text only. With ping-passthrough = "ALL" below
# the client normally sees the C2E2 backend's MOTD; this is the fallback shown
# when C2E2 is unreachable (kept in sync with the backend MOTD in
# docker/proxmox/docker-compose.yml).
# Version segment rewritten in place by publish-prism-pack.ps1 on each publish.
motd = "Craft to Exile 2 v0.4.0"
show-max-players = 20

# Velocity handles Mojang auth; backends run with ONLINE_MODE=FALSE.
online-mode = true
force-key-authentication = true

# Modern forwarding — backends share the secret in forwarding.secret.
# Velocity reads it from /server/forwarding.secret, which on the Azure host is
# a single-file bind mount of /opt/minecraft/secrets/velocity_forwarding_secret
# written by refresh-env.sh from Key Vault.
player-info-forwarding-mode = "modern"

announce-forge = false
kick-existing-players = false
# ALL: Velocity proxies status pings to the C2E2 backend so the client server-list
# reflects real C2E2 health (player count, MOTD, online/offline). With only one
# backend and no lobby, DISABLED would show "online" even when C2E2 is unreachable.
ping-passthrough = "ALL"
enable-player-address-logging = true

[servers]
# Only backend: Craft to Exile 2 on the Proxmox VM, reachable over TailScale.
c2e2 = "${C2E2_TAILSCALE_IP}:25565"

# Single backend — every login goes straight to C2E2.
try = ["c2e2"]

[forced-hosts]
# No forced hosts — all players land on c2e2.

[advanced]
compression-threshold = 256
compression-level = -1
login-ratelimit = 3000
connection-timeout = 5000
read-timeout = 30000
haproxy-protocol = false
tcp-fast-open = false
bungee-plugin-message-channel = true
show-ping-requests = false
failover-on-unexpected-server-disconnect = true
announce-proxy-commands = true
log-command-executions = false
log-player-connections = true
accepts-transfers = false

[query]
enabled = false
port = 25577
map = "Velocity"
max-players = 20
