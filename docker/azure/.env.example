# Required environment variables for the Azure stack
# These are written to /opt/minecraft/docker/azure/.env on the Azure VM by
# docker/azure/refresh-env.sh, which is run by the deploy workflow before
# `docker compose up -d`. Values are fetched from Azure Key Vault at deploy
# time — never stored in the repo.
#
# Key Vault secret names → env vars:
#   tailscale-auth-key          ->  TS_AUTHKEY
#   velocity-forwarding-secret  ->  VELOCITY_FORWARDING_SECRET
#   c2e2-tailscale-ip           ->  C2E2_TAILSCALE_IP  (used in velocity.toml backend config)
#
# Static (no secrets, set by refresh-env.sh from a hardcoded value):
#   TS_HOSTNAME=lobby-azure     — tailnet node name for the lobby VM's sidecar

# Tailscale auth key used by the tailscale Docker sidecar to join the tailnet.
# Generate ephemeral + preauthorized at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Tailnet hostname for the lobby VM's tailscale sidecar. Distinct from the
# host's hostname so the previous host-level tailscale node can be cleaned up
# without colliding.
TS_HOSTNAME=lobby-azure

# Shared secret between Velocity and the C2E2 backend server (modern forwarding)
VELOCITY_FORWARDING_SECRET=

# TailScale IP of the Proxmox VM — Velocity forwards all players to C2E2 at this address
C2E2_TAILSCALE_IP=
