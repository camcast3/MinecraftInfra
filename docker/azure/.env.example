# Required environment variables for the Azure stack
# These are written to /opt/minecraft/.env on the Azure VM by the deploy-azure.yml workflow.
# Values are fetched from Azure Key Vault at deploy time — never stored in the repo.
#
# Key Vault secret names:
#   velocity-forwarding-secret  ->  VELOCITY_FORWARDING_SECRET
#   rcon-password               ->  RCON_PASSWORD
#   c2e2-tailscale-ip           ->  C2E2_TAILSCALE_IP  (used in velocity.toml backend config)
#   storage-account             ->  STORAGE_ACCOUNT    (Azure Blob Storage account name)

# Shared secret between Velocity and all backend MC servers (modern forwarding)
VELOCITY_FORWARDING_SECRET=

# RCON password for the lobby server
RCON_PASSWORD=

# TailScale IP of the Proxmox VM — Velocity routes players to C2E2 via this address
C2E2_TAILSCALE_IP=

# Azure Storage account name for backups (no .blob.core.windows.net suffix).
# The VM's system-assigned Managed Identity must have "Storage Blob Data Contributor"
# on the minecraft-backups container in this storage account.
STORAGE_ACCOUNT=
